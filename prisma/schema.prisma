// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String               @id @default(cuid())
  username            String               @unique
  passwordHash        String?
  isAdmin             Boolean              @default(false)
  accountType         String               @default("PERSONAL") // "PERSONAL" | "EDUCATION" | "TEACHER"
  mustChangePassword  Boolean              @default(false)
  newCardsPerDay      Int                  @default(10)
  newCardsPerDayLocked Boolean             @default(false)
  createdAt           DateTime             @default(now())
  createdById         String?
  createdBy           User?                @relation("CreatedUsers", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers        User[]               @relation("CreatedUsers")
  createdDecks        Deck[]               @relation("CreatedDecks")
  createdGroups       StudentGroup[]       @relation("CreatedGroups")
  progress            UserProgress[]
  dailyStats          UserDeckDailyStat[]
  enrollments         UserDeck[]
  groupMemberships    StudentGroupMember[]
}

model Deck {
  id               String              @id @default(cuid())
  name             String
  description      String?
  visibility       String              @default("PUBLIC") // "PUBLIC" | "EDUCATION_ONLY"
  mode               String              @default("NORMAL") // "NORMAL" | "QUIZ"
  quizChoices        Int                 @default(4)        // 2..10, total options including correct answer
  distractorStrategy String              @default("TAGS")   // "TAGS" | "LEVENSHTEIN_ANSWER" | "LEVENSHTEIN_QUESTION"
  createdAt        DateTime            @default(now())
  createdById      String?
  createdBy        User?               @relation("CreatedDecks", fields: [createdById], references: [id], onDelete: SetNull)
  fields           Field[]
  cards            Card[]
  questionTypes    DeckQuestionType[]
  enrollments      UserDeck[]
  dailyStats       UserDeckDailyStat[]
  groupAssignments DeckGroupAssignment[]
}

model UserDeck {
  id        String   @id @default(cuid())
  userId    String
  deckId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deck      Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@unique([userId, deckId])
}

model DeckQuestionType {
  id               String  @id @default(cuid())
  deckId           String
  showFieldId      String
  askFieldId       String
  position         Int     @default(0)
  useAsQuestion    Boolean @default(true)
  useAsExplanation Boolean @default(false)
  showTtsLang      String?
  showTtsFieldId   String?
  showTtsStopAt    String?
  askTtsLang       String?
  askTtsFieldId    String?
  askTtsStopAt     String?
  showHintFieldIds String?
  askHintFieldIds  String?
  deck             Deck    @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@unique([deckId, showFieldId, askFieldId])
}

model Field {
  id       String      @id @default(cuid())
  deckId   String
  name     String
  position Int
  deck     Deck        @relation(fields: [deckId], references: [id], onDelete: Cascade)
  values   CardValue[]
}

model Card {
  id        String         @id @default(cuid())
  deckId    String
  position  Int            @default(0)
  tags      String         @default("")
  createdAt DateTime       @default(now())
  deck      Deck           @relation(fields: [deckId], references: [id], onDelete: Cascade)
  values    CardValue[]
  progress  UserProgress[]

  @@index([deckId, position])
}

model CardValue {
  id      String @id @default(cuid())
  cardId  String
  fieldId String
  value   String
  card    Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  field   Field  @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([cardId, fieldId])
}

model UserProgress {
  id             String    @id @default(cuid())
  userId         String
  cardId         String
  showFieldId    String
  askFieldId     String
  stability      Float     @default(0)
  difficulty     Float     @default(0)
  state          Int       @default(0)
  reps           Int       @default(0)
  lapses         Int       @default(0)
  scheduledDays  Int       @default(0)
  elapsedDays    Int       @default(0)
  learningSteps  Int       @default(0)
  dueDate        DateTime  @default(now())
  lastReviewed   DateTime?
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  card           Card      @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId, showFieldId, askFieldId])
  @@index([cardId])
}

model UserDeckDailyStat {
  id              String   @id @default(cuid())
  userId          String
  deckId          String
  day             DateTime @db.Date
  reviewCount     Int      @default(0)
  difficultySum   Float    @default(0)
  difficultyCount Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deck            Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@unique([userId, deckId, day])
  @@index([userId, day])
  @@index([deckId, day])
}

model StudentGroup {
  id              String               @id @default(cuid())
  name            String
  createdAt       DateTime             @default(now())
  createdById     String?
  createdBy       User?                @relation("CreatedGroups", fields: [createdById], references: [id], onDelete: SetNull)
  members         StudentGroupMember[]
  deckAssignments DeckGroupAssignment[]
}

model StudentGroupMember {
  id       String   @id @default(cuid())
  userId   String
  groupId  String
  joinedAt DateTime @default(now())
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  group    StudentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model DeckGroupAssignment {
  id        String  @id @default(cuid())
  deckId    String
  groupId   String
  mandatory Boolean @default(false)
  deck      Deck         @relation(fields: [deckId], references: [id], onDelete: Cascade)
  group     StudentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([deckId, groupId])
}

model AppSettings {
  id                       String  @id @default("singleton")
  allowSelfRegistration    Boolean @default(true)
  allowTeacherRegistration Boolean @default(false)
}
